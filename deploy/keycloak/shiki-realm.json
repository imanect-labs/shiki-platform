{
  "realm": "shiki",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 1800,
  "groups": [
    { "name": "acme", "path": "/acme" }
  ],
  "clients": [
    {
      "clientId": "shiki-web",
      "name": "shiki web frontend (BFF confidential client)",
      "description": "メイン Web の BFF（crates/api）が code↔token 交換をサーバ側で行う confidential client。ブラウザにトークンは置かない（docs/auth/browser-token-strategy.md / #55）。",
      "enabled": true,
      "publicClient": false,
      "secret": "shiki-web-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:8080/*"],
      "webOrigins": ["+"],
      "rootUrl": "http://localhost:3000",
      "baseUrl": "http://localhost:3000",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "shiki-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "shiki-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "true",
            "claim.name": "groups",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "roles",
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "skillex",
      "name": "skillex service (DLC/LLM 利用)",
      "description": "skillex が shiki 共有 ID プールへフェデレートし、DLC/LLM 利用トークンを得るための client。詳細は docs/auth/skillex-identity.md。",
      "enabled": true,
      "publicClient": false,
      "secret": "skillex-dev-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3100/*"],
      "protocolMappers": [
        {
          "name": "shiki-llm-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "shiki-llm",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@acme.example",
      "firstName": "Alice",
      "lastName": "Example",
      "attributes": {
        "roles": ["engineering", "sales-div"]
      },
      "groups": ["/acme"],
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
