# shiki-platform compose 環境変数のサンプル。`.env` にコピーして使う。

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Keycloak 管理者 ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# ブラウザからアクセスする Keycloak の公開 URL（トークンの iss になる）。
KC_PUBLIC_URL=http://localhost:8081

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- shiki-server ---
# OIDC issuer はブラウザがログインする公開 URL に一致させる（authorize/ログアウトのリダイレクト先）。
SHIKI__AUTH__ISSUER=http://localhost:8081/realms/shiki
# サーバ側 OIDC 呼び出し（token 交換・JWKS）はコンテナ内部 URL を使う。
SHIKI__AUTH__INTERNAL_BASE_URL=http://keycloak:8080/realms/shiki
SHIKI__AUTH__AUDIENCE=shiki-api
# テナンシー: multi（SaaS）は JWT claim `tenant` 由来の tenant_id で Postgres レイヤを分離する。
# alice/bob=tenant a-corp・charlie=tenant b-corp（realm の tenant 属性）。テナント分離の検証用。
# single（オンプレ/cell）にする場合は SHIKI__AUTH__TENANT_ID の固定値を使う。
SHIKI__AUTH__TENANCY=multi
# multi は本番では fail-closed。dev/test で使うため明示 opt-in する（SAAS.1 完了で不要に）。
SHIKI_DEV_ALLOW_MULTI_TENANT=true
# BFF（confidential client）。client_secret はサーバ側でのみ保持する（ブラウザに出さない）。
SHIKI__AUTH__CLIENT_ID=shiki-web
SHIKI__AUTH__CLIENT_SECRET=shiki-web-dev-secret
# OIDC code フローの redirect_uri。web 同一オリジン運用は http://localhost:3000/auth/callback。
# web 無しの smoke では api 自身（http://localhost:8080/auth/callback）。
SHIKI__AUTH__REDIRECT_URI=http://localhost:8080/auth/callback
SHIKI__AUTH__POST_LOGOUT_REDIRECT_URI=http://localhost:8080/

# --- BFF セッション (Redis) ---
# ローカル HTTP 開発では Cookie の Secure を無効化する（本番 HTTPS は true）。
SHIKI__SESSION__SECURE=false

# 開発/E2E 用: 起動時に固定ユーザー群（alice/bob=a-corp・charlie=b-corp）の
# org member tuple ＋ ユーザーディレクトリ（共有相手検索）を seed する。
# realm の sub / tenant 属性 / groups と一致させること（crates/api/src/main.rs SEED_USERS）。
# SHIKI_DEV_SEED=true のときのみ作動する（本番では設定しないこと＝権限昇格経路のため）。
SHIKI_DEV_SEED=true

# --- 監視（observability profile・オプトイン） ---
# 監視スタックを使う時だけ有効化する:
#   OTLP_ENDPOINT=http://otel-collector:4317 docker compose --profile observability up -d
# 空 = OTel エクスポート無効（開発機の RAM 節約のための既定）。
OTLP_ENDPOINT=

# --- RAG（Phase 2） ---
# false にするとインジェスト・パイプラインと POST /search を無効化できる。
SHIKI__RAG__ENABLED=true
# 埋め込みモデル版。インデックス（Qdrant collection / Tantivy index）単位で固定され、
# 変更時は shadow index を再構築して alias を切り替える（docs/design.md §4.3 PIT-8）。
SHIKI__RAG__EMBEDDING_MODEL_VERSION=cl-nagoya/ruri-v3-30m
