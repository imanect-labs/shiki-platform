# shiki-platform compose 環境変数のサンプル。`.env` にコピーして使う。

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Keycloak 管理者 ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# ブラウザからアクセスする Keycloak の公開 URL（トークンの iss になる）。
KC_PUBLIC_URL=http://localhost:8081

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- shiki-server ---
# OIDC issuer はブラウザがログインする公開 URL に一致させる。
SHIKI__AUTH__ISSUER=http://localhost:8081/realms/shiki
# JWKS はコンテナ内ネットワークから取得する内部 URL を明示する。
SHIKI__AUTH__JWKS_URI=http://keycloak:8080/realms/shiki/protocol/openid-connect/certs
SHIKI__AUTH__AUDIENCE=shiki-api

# 開発/E2E 用: 起動時にこのユーザーの org member tuple を seed する
# （realm のテストユーザー id と groups(/acme) に一致させること）。
SHIKI_DEV_SEED_USER=00000000-0000-0000-0000-000000000001
SHIKI_DEV_SEED_ORG=acme
